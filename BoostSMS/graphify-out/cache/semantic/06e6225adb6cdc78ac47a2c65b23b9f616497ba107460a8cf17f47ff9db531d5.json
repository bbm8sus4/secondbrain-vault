{"nodes": [{"id": "_knowledge_k15_ab_testing_sms", "label": "K15 A/B Testing for SMS Campaigns", "file_type": "document", "source_file": "_knowledge/K15-AB-Testing-SMS.md", "source_location": null, "source_url": null, "captured_at": "2026-07-06", "author": null, "contributor": null}, {"id": "_knowledge_k15_ab_testing_sms_sample_size", "label": "SMS A/B Test Sample Size Constraint", "file_type": "rationale", "source_file": "_knowledge/K15-AB-Testing-SMS.md", "source_location": null, "source_url": null, "captured_at": "2026-07-06", "author": null, "contributor": null, "rationale": "SMS has no open tracking, so tests live on CTR/conversion via unique short links per variant. At ~10% baseline CTR you need ~1,500-2,500 recipients per variant to detect a 20% relative lift (95% confidence / 80% power); conversion tests need far more. Standard play: 10/10/80 split (test 10% + 10%, blast winner to 80%), randomize truly, send variants simultaneously, no peeking, opt-out rate as guardrail, one variable at a time, keep a shared test log, re-test every 1-2 quarters. Small lists should only test bold differences. Every variant costs real money (THB 0.2-0.8/msg), so design the smallest test that answers the question."}], "edges": [{"source": "_knowledge_k15_ab_testing_sms", "target": "_knowledge_k06_sms_metrics_kpis", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K15-AB-Testing-SMS.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k15_ab_testing_sms", "target": "_knowledge_k07_timing_frequency", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K15-AB-Testing-SMS.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k15_ab_testing_sms", "target": "_knowledge_k03_sms_copywriting", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K15-AB-Testing-SMS.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k15_ab_testing_sms", "target": "_knowledge_k05_segmentation_targeting", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K15-AB-Testing-SMS.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k15_ab_testing_sms", "target": "_knowledge_k14_compliance_antispam", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K15-AB-Testing-SMS.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k15_ab_testing_sms", "target": "_knowledge_k15_ab_testing_sms_sample_size", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K15-AB-Testing-SMS.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k15_ab_testing_sms", "target": "_knowledge_k05_segmentation_targeting_holdout_group", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K15-AB-Testing-SMS.md", "source_location": "Section 4: Holdout Group (advanced) for incremental lift", "weight": 1.0}], "hyperedges": []}