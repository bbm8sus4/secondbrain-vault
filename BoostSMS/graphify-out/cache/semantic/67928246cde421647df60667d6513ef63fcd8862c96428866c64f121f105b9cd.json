{"nodes": [{"id": "_knowledge_k04_campaign_types", "label": "K04 SMS Campaign Types", "file_type": "document", "source_file": "_knowledge/K04-Campaign-Types.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_knowledge_k04_campaign_types_five_archetypes", "label": "5 SMS Campaign Archetypes", "file_type": "concept", "source_file": "_knowledge/K04-Campaign-Types.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Promotional (revenue), Transactional (functional, no marketing opt-in needed under NBTC service-message rules), OTP (security, dedicated sender, no links), Drip/Sequence (nurture), Trigger-based (behavior response). Each archetype has different KPIs, regulatory treatment and ROI profile."}, {"id": "_knowledge_k04_campaign_types_trigger_based", "label": "Trigger-based SMS Campaigns", "file_type": "rationale", "source_file": "_knowledge/K04-Campaign-Types.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Highest-ROI SMS usage because messages respond to customer action/inaction (cart abandonment converts 15-30%, loyalty point expiry, win-back, birthday, appointment reminders cut no-shows 40%+). Most SME mistakes come from treating all SMS as mass broadcasts; the intended path is to start with segmented promotional and migrate up to trigger-based as data + automation mature."}], "edges": [{"source": "_knowledge_k04_campaign_types", "target": "_knowledge_k03_sms_copywriting", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K04-Campaign-Types.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k04_campaign_types", "target": "_knowledge_k05_segmentation_targeting", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K04-Campaign-Types.