{"nodes": [{"id": "_knowledge_k13_deliverability_dlr", "label": "K13 Deliverability & DLR", "file_type": "document", "source_file": "_knowledge/K13-Deliverability-DLR.md", "source_location": null, "source_url": null, "captured_at": "2026-07-06", "author": null, "contributor": null}, {"id": "_knowledge_k13_deliverability_dlr_dlr", "label": "DLR (Delivery Report)", "file_type": "concept", "source_file": "_knowledge/K13-Deliverability-DLR.md", "source_location": null, "source_url": null, "captured_at": "2026-07-06", "author": null, "contributor": null, "rationale": "Sent != Delivered: DLR is the operator's receipt that the handset actually got the message. SMPP statuses DELIVRD/ACCEPTD/ENROUTE/UNDELIV/EXPIRED/REJECTD/DELETED/UNKNOWN. Benchmark: delivery > 95% on clean lists via direct routes; monitor per operator, use seed numbers, treat a one-operator drop as a filter/route incident, and keep DLR logs to answer customer disputes. Top Thai delivery killers: unregistered sender (hard block), operator content filters, dead/recycled numbers, phones off past validity period."}, {"id": "_knowledge_k13_deliverability_dlr_grey_route", "label": "Grey Route", "file_type": "concept", "source_file": "_knowledge/K13-Deliverability-DLR.md", "source_location": null, "source_url": null, "captured_at": "2026-07-06", "author": null, "contributor": null, "rationale": "Abnormally cheap routes (THB 0.10-0.20) that bypass operators; forbidden. Often return fake DELIVRD DLRs \u2014 suspect grey route when delivery reports look perfect (100% DELIVRD) but CTR is abnormally low or customers report missing OTPs, or when UNKNOWN statuses are frequent."}], "edges": [{"source": "_knowledge_k13_deliverability_dlr", "target": "_knowledge_k06_sms_metrics_kpis", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K13-Deliverability-DLR.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k13_deliverability_dlr", "target": "_knowledge_k08_thai_sms_market_nbtc", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K13-Deliverability-DLR.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k13_deliverability_dlr", "target": "_knowledge_k09_sender_name_thailand", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K13-Deliverability-DLR.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k13_deliverability_dlr", "target": "_knowledge_k14_compliance_antispam", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K13-Deliverability-DLR.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k13_deliverability_dlr", "target": "_knowledge_k03_sms_copywriting", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K13-Deliverability-DLR.md", "source_location": "Checklist: avoid trigger words, vary templates", "weight": 1.0}, {"source": "_knowledge_k13_deliverability_dlr", "target": "_knowledge_k07_timing_frequency", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K13-Deliverability-DLR.md", "source_location": "Checklist: send within 08:00-21:00", "weight": 1.0}, {"source": "_knowledge_k13_deliverability_dlr", "target": "_knowledge_k13_deliverability_dlr_dlr", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K13-Deliverability-DLR.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k13_deliverability_dlr", "target": "_knowledge_k13_deliverability_dlr_grey_route", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K13-Deliverability-DLR.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k13_deliverability_dlr_grey_route", "target": "_knowledge_k13_deliverability_dlr_dlr", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K13-Deliverability-DLR.md", "source_location": "Grey routes return fake DELIVRD DLRs", "weight": 1.0}, {"source": "_knowledge_k13_deliverability_dlr", "target": "_knowledge_k09_sender_name_thailand_sender_name", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K13-Deliverability-DLR.md", "source_location": "Unregistered Sender ID = #1 delivery killer in Thailand", "weight": 1.0}], "hyperedges": []}