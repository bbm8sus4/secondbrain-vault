{"nodes": [{"id": "_knowledge_k03_sms_copywriting", "label": "K03 SMS Copywriting (70 Thai chars)", "file_type": "document", "source_file": "_knowledge/K03-SMS-Copywriting.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_knowledge_k03_sms_copywriting_sms_encoding", "label": "SMS Encoding GSM-7 vs UCS-2", "file_type": "concept", "source_file": "_knowledge/K03-SMS-Copywriting.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The hidden tax of SMS: GSM-7 allows 160 chars (EN), but Thai forces UCS-2 (16-bit) so 140-byte payload / 2 = 70 chars per segment (67 when concatenated). A single emoji flips even English text to UCS-2. Segment count drives per-message cost, which is why copy brevity and avoiding emojis matter commercially."}], "edges": [{"source": "_knowledge_k03_sms_copywriting", "target": "_knowledge_k04_campaign_types", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K03-SMS-Copywriting.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k03_sms_copywriting", "target": "_knowledge_k14_compliance_antispam", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K03-SMS-Copywriting.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k03_sms_copywriting", "target": "_knowledge_k15_ab_testing_sms", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K03-SMS-Copywriting.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k03_sms_copywriting", "target": "_knowledge_k03_sms_copywriting_sms_encoding", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K03-SMS-Copywriting.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k03_sms_copywriting", "target":