{"nodes": [{"id": "_assets_index", "label": "BoostSMS Project Overview (index.html)", "file_type": "document", "source_file": "_assets/index.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_assets_index_boostsms", "label": "BoostSMS Platform", "file_type": "concept", "source_file": "_assets/index.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "SaaS bulk-SMS platform for Thai business (boost-sms.com / app.boost-sms.com / backoffice.boost-sms.com): Web SMS (Excel/CSV upload, scheduling), OTP & 2FA, RESTful SMS API, real-time dashboard/reports with tracking links (click = hot lead). NBTC-certified, all 3 operators, live since 15 Aug 2568 after source-code purchase + 5-week dev (UAT: 99.8% delivery, 145ms latency, 0 critical bugs). Owned by EasySlip Co. under the Thunder Solution brand."}, {"id": "_assets_index_easyslip", "label": "\u0e1a\u0e23\u0e34\u0e29\u0e31\u0e17 \u0e2d\u0e35\u0e0b\u0e35\u0e48\u0e2a\u0e25\u0e34\u0e1b \u0e08\u0e33\u0e01\u0e31\u0e14 (EasySlip Co.)", "file_type": "concept", "source_file": "_assets/index.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Product owner of BoostSMS; slip-verification company whose customer base is the built-in cross-sell channel for BoostSMS (EasySlip customers wanting SMS = a named winning segment)."}, {"id": "_assets_index_thunder_solution", "label": "Thunder Solution (brand)", "file_type": "concept", "source_file": "_assets/index.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_assets_index_moonrhythm", "label": "\u0e1a\u0e23\u0e34\u0e29\u0e31\u0e17 \u0e21\u0e39\u0e19\u0e23\u0e36\u0e17\u0e36\u0e48\u0e21 \u0e08\u0e33\u0e01\u0e31\u0e14 (Source Code Vendor)", "file_type": "concept", "source_file": "_assets/index.html", "source_location