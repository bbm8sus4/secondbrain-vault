{"nodes": [{"id": "_knowledge_k08_thai_sms_market_nbtc", "label": "K08 Thai SMS Market & NBTC Regulation", "file_type": "document", "source_file": "_knowledge/K08-Thai-SMS-Market-NBTC.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_knowledge_k08_thai_sms_market_nbtc_nbtc", "label": "NBTC (\u0e01\u0e2a\u0e17\u0e0a.)", "file_type": "concept", "source_file": "_knowledge/K08-Thai-SMS-Market-NBTC.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Thailand's telecom regulator (est. 2553). For SMS: mandates Sender ID registration with each operator, restricts promotional sends to 08:00-21:00 (OTP/transactional 24h), requires opt-out, handles consumer complaints; penalties range from fines (THB 20k-200k) to sender suspension and 3-operator blacklist for repeat offenders."}, {"id": "_knowledge_k08_thai_sms_market_nbtc_ais", "label": "AIS (Advanced Info Service)", "file_type": "concept", "source_file": "_knowledge/K08-Thai-SMS-Market-NBTC.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "~45% market share; wide reach and good speed but the strictest spam filter (trigger words, unapproved sender block, volume-spike throttling, repeated-template flagging)."}, {"id": "_knowledge_k08_thai_sms_market_nbtc_truemove_h", "label": "TrueMove H (True Corporation)", "file_type": "concept", "source_file": "_knowledge/K08-Thai-SMS-Market-NBTC.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "~35% market share; fast routing in Bangkok but filter rules change frequently. Post-merger absorbs dtac traffic."}, {"id": "_knowledge_k08_thai_sms_market_nbtc_dtac", "label": "dtac (merged with True)", "file_type": "concept", "source_file": "_knowledge/K08-Thai-SMS-Market-NBTC.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "~15-20% share; merged with True in 2566 (dtac-True), in practice runs on True infrastructure \u2014 effectively Thailand has 2 operators (AIS + True/dtac) plus NT."}], "edges": [{"source": "_knowledge_k08_thai_sms_market_nbtc", "target": "_knowledge_k09_sender_name_thailand", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K08-Thai-SMS-Market-NBTC.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k08_thai_sms_market_nbtc", "target": "_knowledge_k14_compliance_antispam", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K08-Thai-SMS-Market-NBTC.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k08_thai_sms_market_nbtc", "target": "_knowledge_k13_deliverability_dlr", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K08-Thai-SMS-Market-NBTC.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k08_thai_sms_market_nbtc", "target": "_knowledge_k12_competitor_landscape", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K08-Thai-SMS-Market-NBTC.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k08_thai_sms_market_nbtc", "target": "02_packages_pricing", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K08-Thai-SMS-Market-NBTC.md", "source_location": "Section 5: BoostSMS Pricing Context", "weight": 1.0}, {"source": "_knowledge_k08_thai_sms_market_nbtc", "target": "_knowledge_k08_thai_sms_market_nbtc_nbtc", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K08-Thai-SMS-Market-NBTC.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k08_thai_sms_market_nbtc", "target": "_knowledge_k08_