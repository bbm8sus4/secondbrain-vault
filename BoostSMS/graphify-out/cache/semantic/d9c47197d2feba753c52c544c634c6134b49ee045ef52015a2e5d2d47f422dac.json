{"nodes": [{"id": "_knowledge_k02_channel_comparison", "label": "K02 Channel Comparison (SMS vs Email vs LINE vs RCS vs Push)", "file_type": "document", "source_file": "_knowledge/K02-Channel-Comparison.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_knowledge_k02_channel_comparison_rcs", "label": "RCS (Rich Communication Services)", "file_type": "concept", "source_file": "_knowledge/K02-Channel-Comparison.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "'SMS 2.0' \u2014 unlimited chars, images, video, carousel, CTA buttons, read receipts, verified sender. Adopted in US/EU but <5% reach in Thailand; BoostSMS intends to integrate RCS only when a Thai operator standard emerges (expected >30% penetration by 2027)."}, {"id": "_knowledge_k02_channel_comparison_channel_orchestration", "label": "Multi-Channel Orchestration Strategy", "file_type": "rationale", "source_file": "_knowledge/K02-Channel-Comparison.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "No single channel wins everything: SMS for must-read/urgent, LINE OA for engagement/2-way, email for long-form content, push for already-active app users. Best practice is 3-4 channels sequenced per campaign (e.g., email teaser -> LINE preview -> SMS launch -> push mid-sale -> SMS last call). In Thailand: LINE = day-to-day, SMS = critical moments."}], "edges": [{"source": "_knowledge_k02_channel_comparison", "target": "_knowledge_k01_sms_marketing_fundamentals", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K02-Channel-Comparison.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k02_channel_comparison", "target": "_knowledge_k03_sms_copywriting", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_f