{"nodes": [{"id": "_knowledge_k14_compliance_antispam", "label": "K14 Compliance & Anti-Spam (PDPA, NBTC, Opt-in/out)", "file_type": "document", "source_file": "_knowledge/K14-Compliance-AntiSpam.md", "source_location": null, "source_url": null, "captured_at": "2026-07-06", "author": null, "contributor": null}, {"id": "_knowledge_k14_compliance_antispam_pdpa", "label": "PDPA (Thai Personal Data Protection Act)", "file_type": "concept", "source_file": "_knowledge/K14-Compliance-AntiSpam.md", "source_location": null, "source_url": null, "captured_at": "2026-07-06", "author": null, "contributor": null, "rationale": "B.E. 2562, fully enforced June 2565. A phone number is personal data, so marketing SMS requires valid consent: freely given, specific, informed, unambiguous (no pre-ticked boxes), revocable. Keep proof of consent (who/when/channel/consent text version) \u2014 'no consent record = don't send'. Forbidden: bought lists, blasting old transaction numbers without marketing consent, sharing lists beyond consent scope. Administrative fines up to THB 5M per case plus criminal exposure and brand damage."}, {"id": "_knowledge_k14_compliance_antispam_opt_out", "label": "Opt-out Requirement (STOP)", "file_type": "concept", "source_file": "_knowledge/K14-Compliance-AntiSpam.md", "source_location": null, "source_url": null, "captured_at": "2026-07-06", "author": null, "contributor": null, "rationale": "Mandatory on every promotional SMS ('\u0e1e\u0e34\u0e21\u0e1e\u0e4c STOP \u0e40\u0e1e\u0e37\u0e48\u0e2d\u0e40\u0e25\u0e34\u0e01\u0e23\u0e31\u0e1a', *137 operator channel, or preference link). Must be processed fast (within 24h, ideally immediately), be permanent via suppression list, and never trigger extra 'confirmation' SMS. Transactional/OTP messages are exempt from marketing consent but must not smuggle in promo content \u2014 a promo tail turns the whole message into marketing."}, {"id": "_knowledge_k14_compliance_antispam_suppression_list", "label": "Suppression List", "file_type": "concept", "source_file": "_knowledge/K14-Compliance-AntiSpam.md", "source_location": null, "source_url": null, "captured_at": "2026-07-06", "author": null, "contributor": null, "rationale": "Single permanent blacklist that every opt-out channel (STOP, call center, LINE, email) flows into; every new list import must be checked against it before sending. Complements campaign-level exclusion lists (recent contacts, recent buyers, dead numbers with repeated DLR failures)."}, {"id": "_knowledge_k14_compliance_antispam_tcpa", "label": "TCPA (US reference)", "file_type": "concept", "source_file": "_knowledge/K14-Compliance-AntiSpam.md", "source_location": null, "source_url": null, "captured_at": "2026-07-06", "author": null, "contributor": null, "rationale": "US benchmark showing how expensive SMS spam can get: statutory damages $500-$1,500 per message, class actions worth hundreds of millions (e.g., T-Mobile 2020 $5M+ settlement). Doc's stance: 'Thai minimum + EU-grade discipline' is safe in every market and a selling point for enterprise customers."}], "edges": [{"source": "_knowledge_k14_compliance_antispam", "target": "_knowledge_k08_thai_sms_market_nbtc", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K14-Compliance-AntiSpam.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k14_compliance_antispam", "target": "_knowledge_k09_sender_name_thailand", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K14-Compliance-AntiSpam.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k14_compliance_antispam", "target": "_knowledge_k03_sms_copywriting", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K14-Compliance-AntiSpam.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k14_compliance_antispam", "target": "_knowledge_k07_timing_frequency", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K14-Compliance-AntiSpam.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k14_compliance_antispam", "target": "_knowledge_k13_deliverability_dlr", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K14-Compliance-AntiSpam.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k14_compliance_antispam", "target": "_knowledge_k06_sms_metrics_kpis", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K14-Compliance-AntiSpam.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k14_compliance_antispam", "target": "_knowledge_k14_compliance_antispam_pdpa", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K14-Compliance-AntiSpam.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k14_compliance_antispam", "target": "_knowledge_k14_compliance_antispam_opt_out", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K14-Compliance-AntiSpam.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k14_compliance_antispam", "target": "_knowledge_k14_compliance_antispam_suppression_list", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K14-Compliance-AntiSpam.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k14_compliance_antispam", "target": "_knowledge_k14_compliance_antispam_tcpa", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "_knowledge/K14-Compliance-AntiSpam.md", "source_location": null, "weight": 1.0}, {"source": "_knowledge_k14_compliance_antispam", "target": "_knowledge_k08_thai_sms_market_nbtc_nbtc", "relation": "references", "confidence": "EXTRACTED", "confide