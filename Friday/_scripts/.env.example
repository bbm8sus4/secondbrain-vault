# Friday recap alerts — copy to .env to enable Telegram alerts on failure.
# macOS notifications fire either way (no config needed).
#
# To enable Telegram alerts:
#   1. Get bot token from @BotFather
#   2. Get your user ID by messaging @userinfobot
#   3. cp .env.example .env
#   4. Fill in the values below
#   5. chmod 600 .env

TG_BOT_TOKEN=
TG_BOSS_ID=
