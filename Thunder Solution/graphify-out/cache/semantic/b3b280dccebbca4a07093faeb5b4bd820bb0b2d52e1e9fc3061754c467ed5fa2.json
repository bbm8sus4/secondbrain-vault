{"nodes": [{"id": "03_revenue_commission", "label": "Thunder Solution \u2014 Revenue & Commission (KB doc)", "file_type": "document", "source_file": "03-Revenue-Commission.md", "source_location": null, "source_url": null, "captured_at": "2026-07-06T00:00:00", "author": null, "contributor": null}, {"id": "03_revenue_commission_corporate_api_commission_model", "label": "Corporate API sales commission model", "file_type": "rationale", "source_file": "03-Revenue-Commission.md", "source_location": null, "source_url": null, "captured_at": "2026-07-06T00:00:00", "author": null, "contributor": null, "rationale": "Commission tied to cost scenario: 3% of revenue under Scenario A (net ~9%) or 8% under Scenario B (net ~30%); off-table tiers use per-slip commission 0.00375 (A) / 0.010 (B). Caveats: Net GP \u2260 Net Profit (opex ~10\u201320% not deducted; excl/incl VAT not separated \u2014 consult accounting). Comes with a 6-step Sales Playbook and a 4-sheet Excel used by the sales team."}, {"id": "03_revenue_commission_cost_scenario_a", "label": "Cost Scenario A (Other-source 100%, cost 0.110, GP 12%)", "file_type": "rationale", "source_file": "03-Revenue-Commission.md", "source_location": null, "source_url": null, "captured_at": "2026-07-06T00:00:00", "author": null, "contributor": null, "rationale": "Conservative pricing floor: assumes all traffic is Other-source at 0.11 KBank cost, so commission capped at 3% to keep ~9% net margin."}, {"id": "03_revenue_commission_cost_scenario_b", "label": "Cost Scenario B (mix blend ~30/70, cost 0.077, GP 38.4%)", "file_type": "rationale", "source_file": "03-Revenue-Commission.md", "source_location": null, "source_url": null, "captured_at": "2026-07-06T00:00:00", "author": null, "contributor": null, "rationale": "Higher-margin scenario allowing 8% commission, but only valid if traffic mix holds \u2014 the MOU must lock K-source \u2265 30%, otherwise blended cost exceeds 0.077 and margin disappears."}, {"id": "03_revenue_commission_cross_billing_thunder_easy", "label": "Thunder \u2192 Easy cross-billing formula", "file_type": "rationale", "source_file": "03-Revenue-Commission.md", "source_location": null, "source_url": null, "captured_at": "2026-07-06T00:00:00", "author": null, "contributor": null, "rationale": "K2K \u00d7 0.04 flat (Thunder keeps margin because it pays KBank at 0.025\u20130.035 tiers) + Others \u00d7 0.11 flat (pure pass-through) + VAT 7%. Easy depends on Thunder for ~94.7% of traffic (~12.5M calls/month, \u0e18.\u0e04. 2568). Real levers: push customers to scan from KBank app (Others is 2.75\u00d7 dearer), review intercompany fairness, verify bills monthly, and claim ~\u0e3f884K THUNDER overpayment for \u0e18.\u0e04. 2568 (claim status unknown \u2014 verify)."}], "edges": [{"source": "03_revenue_commission", "target": "revenue_2569_01_to_05_revenue_report", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "03-Revenue-Commission.md", "source_location": null, "weight": 1.0}, {"source": "03_revenue_commission", "target": "01_overview", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "03-Revenue-Commission.md", "source_location": null, "weight": 1.0}, {"source": "03_revenue_commission", "target": "02_products_services", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "03-Revenue-Commission.md", "source_location": null, "weight": 1.0}, {"source": "03_revenue_commission_corporate_api_commission_model", "target": "02_products_services_thunder_corporate_api", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "03-Revenue-Commission.md", "source_location": null, "weight": 1.0}, {"source": "03_revenue_commission_cost_scenario_a", "target": "03_revenue_commission_corporate_api_commission_model", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "03-Revenue-Commis