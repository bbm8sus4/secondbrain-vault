filters:
  and:
    - file.ext == "md"
views:
  - type: table
    name: ทุกหน้า (ล่าสุดก่อน)
    order:
      - file.name
      - note.type
      - note.status
      - note.last_verified
      - file.folder
    sort:
      - property: note.last_verified
        direction: DESC
  - type: table
    name: ยังไม่มี type (schema debt)
    filters:
      and:
        - '!note.type'
        - '!file.path.startsWith("04 Archive")'
        - '!file.path.startsWith("40 Meeting Notes")'
        - '!file.path.startsWith("00 Inbox")'
        - '!file.path.startsWith("30 Claude Memory")'
    order:
      - file.name
      - file.folder
      - file.mtime
    sort:
      - property: file.mtime
        direction: DESC
  - type: table
    name: Projects
    filters:
      and:
        - note.type == "project"
    order:
      - file.name
      - note.status
      - note.last_verified
    sort:
      - property: note.last_verified
        direction: DESC
  - type: table
    name: คิวรอ verify / draft
    filters:
      and:
        - note.status != "live"
        - note.type
    order:
      - file.name
      - note.type
      - note.status
      - note.last_verified
    sort:
      - property: note.last_verified
        direction: ASC
